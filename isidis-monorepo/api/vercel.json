{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "src/handler.ts",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "src/handler.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/src/handler"
    }
  ]
}
