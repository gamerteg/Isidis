# Server
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@isidis.com.br

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Cron
CRON_SECRET=your-cron-secret

# JWT (used to verify Supabase JWTs)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Firebase Admin SDK (push notifications)
# Obter em: console.firebase.google.com → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Mercado Pago
MERCADOPAGO_PUBLIC_KEY=APP_USR-your-public-key
MERCADOPAGO_ACCESS_TOKEN=APP_USR-your-access-token
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret
MERCADOPAGO_CARD_FEE_PERCENT=0.0499
MERCADOPAGO_CARD_FEE_FIXED=30
